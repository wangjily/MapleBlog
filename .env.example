# 环境配置示例文件
# 复制此文件为 .env 并填入实际的配置值

# 网站基础配置
PUBLIC_SITE_URL=http://localhost:4321
# 环境：development/production/test
PUBLIC_ENV=development
# 是否开启调试模式
PUBLIC_DEBUG=true
# 日志级别：debug/info/warn/error
PUBLIC_LOG_LEVEL=info

# ========== 评论系统 (Giscus) ==========
# 访问 https://giscus.app 获取配置
# 1. 登录 GitHub
# 2. 选择你的仓库（需要开启 GitHub Discussions）
# 3. 复制下面的配置值

# 仓库格式：用户名/仓库名
PUBLIC_GISCUS_REPO=你的GitHub用户名/你的仓库名

# 从 giscus.app 生成的 Repo ID
PUBLIC_GISCUS_REPO_ID=

# 讨论分类名称（通常用 Announcements）
PUBLIC_GISCUS_CATEGORY=Announcements

# 从 giscus.app 生成的 Category ID
PUBLIC_GISCUS_CATEGORY_ID=

# 其他可选配置（一般不需要改）
# PUBLIC_GISCUS_MAPPING=pathname
# PUBLIC_GISCUS_REACTIONS_ENABLED=1
# PUBLIC_GISCUS_EMIT_METADATA=0
# PUBLIC_GISCUS_INPUT_POSITION=bottom
# PUBLIC_GISCUS_LANG=zh-CN
