---
const { slug, hidden = false } = Astro.props as {
  slug: string;
  hidden?: boolean;
};
---

<span id="view-count" class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400" style={hidden ? 'display:none' : ''}>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.478 0-8.268-2.943-9.542-7zM10 5c-3.478 0-6.542 2.24-7.708 5 1.166 2.76 4.23 5 7.708 5 3.478 0 6.542-2.24 7.708-5C16.542 7.24 13.478 5 10 5z" clip-rule="evenodd" />
  </svg>
  <span id="view-count-number" class="tabular-nums">--</span>
  <span class="ml-1">次浏览</span>
</span>

<script type="module" define:vars={{ slug }}>
  // @ts-nocheck
  const DEDUP_KEY = `view_incremented::${slug}`;
  const DEDUP_MS = 60 * 60 * 1000; // 1 小时去重（同一客户端 1 小时内只计一次）

  let countEl = document.getElementById('view-count-number');

  function renderCount(n) {
    if (countEl) countEl.textContent = String(n ?? 0);
  }

  function getDedupeState() {
    try {
      const raw = localStorage.getItem(DEDUP_KEY);
      if (!raw) return 0;
      const parsed = JSON.parse(raw);
      return typeof parsed.ts === 'number' ? parsed.ts : 0;
    } catch {
      return 0;
    }
  }

  function setDedupeState() {
    try {
      localStorage.setItem(DEDUP_KEY, JSON.stringify({ ts: Date.now() }));
    } catch {
      // 无痕模式等场景忽略
    }
  }

  async function fetchCount() {
    try {
      const res = await fetch(`/api/view-count?slug=${encodeURIComponent(slug)}`);
      if (res.ok) {
        const data = await res.json();
        return data.count ?? 0;
      }
    } catch {
      // 网络错误等忽略
    }
    return null;
  }

  async function incrementAndFetch() {
    const lastTs = getDedupeState();
    const now = Date.now();

    if (now - lastTs >= DEDUP_MS) {
      setDedupeState();
      try {
        await fetch('/api/view-count', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });
      } catch {
        // 忽略
      }
    }

    return fetchCount();
  }

  async function init() {
    const serverCount = await fetchCount();
    if (serverCount !== null) {
      renderCount(serverCount);
    }

    incrementAndFetch().then((count) => {
      if (count !== null) renderCount(count);
    });
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) {
      setTimeout(async () => {
        const count = await fetchCount();
        if (count !== null) renderCount(count);
      }, 200);
    }
  });
</script>
