<div id="tcomment" class="markdown-content twikoo-container"></div>

<script define:vars={{
  twikooEnvId: import.meta.env.PUBLIC_TWIKOO_ENV_ID || ""
}}>
  document.addEventListener("astro:page-load", () => {
    function loadTwikoo() {
      const commentsContainer = document.getElementById("tcomment");
      if (!commentsContainer) return;

      if (!twikooEnvId || twikooEnvId.includes("your-twikoo")) {
        commentsContainer.innerHTML = `
          <div class="text-center py-10 px-4">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-orange-500/10 mb-4">
              <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-txt-p dark:text-darkmode-txt-p mb-2">评论区未配置</h3>
            <p class="text-sm text-txt-light dark:text-darkmode-txt-light mb-1">请在 <code class="px-1.5 py-0.5 rounded bg-white/50 dark:bg-black/50 text-orange-500 text-xs">.env</code> 文件中配置 Twikoo 环境 ID</p>
            <p class="text-xs text-txt-light dark:text-darkmode-txt-light/60 mt-2 leading-relaxed">
              1. 部署 Twikoo →
              <a href="https://twikoo.js.org/quick-start.html" target="_blank" rel="noopener" class="text-orange-500 hover:underline">twikoo.js.org</a><br/>
              2. 获取环境 ID，填入 <code class="px-1 py-0.5 rounded bg-white/50 dark:bg-black/50 text-xs">PUBLIC_TWIKOO_ENV_ID</code>
            </p>
          </div>
        `;
        return;
      }

      const script = document.createElement("script");
      script.src = "https://cdn.jsdelivr.net/npm/twikoo@1.6.44/dist/twikoo.min.js";
      script.async = true;
      script.onload = () => {
        const initScript = document.createElement("script");
        initScript.innerHTML = `
          twikoo.init({
            envId: '${twikooEnvId}',
            el: '#tcomment',
          });
        `;
        document.body.appendChild(initScript);
      };
      script.onerror = () => {
        const container = document.getElementById("tcomment");
        if (container) {
          container.innerHTML = '<p class="text-center text-red-500 py-8">评论区加载失败，请检查网络后刷新重试。</p>';
        }
      };
      document.body.appendChild(script);
    }

    loadTwikoo();
  });
</script>
